{
  "name": "dev-whatsapp-assistant",
  "version": "1.0.0",
  "description": "Developer WhatsApp Assistant - Intent routing and coding brain",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "start:bridge": "node src/index-bridge.js",
    "start:legacy": "node src/index.js",
    "dev": "node --watch src/index.js",
    "dev:bridge": "node --watch src/index-bridge.js",
    "test": "node src/test-safety.js",
    "python:start": "python -m app.main",
    "python:test": "python -m pytest tests/ -v"
  },
  "keywords": [
    "developer",
    "assistant",
    "whatsapp",
    "ai",
    "bot"
  ],
  "author": "Dev Assistant Team",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@google/generative-ai": "^0.21.0",
    "@whiskeysockets/baileys": "^6.7.8",
    "better-sqlite3": "^11.5.0",
    "dotenv": "^16.4.7",
    "openai": "^4.77.3",
    "pino": "^9.5.0",
    "pino-pretty": "^13.1.3",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2"
  }
}
