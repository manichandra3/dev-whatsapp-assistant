# LLM Provider Configuration
# Choose one: openai, anthropic, google
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# API Keys (only the active provider's key is required)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...

# Database
DATABASE_PATH=./data/dev_assistant.db

# WhatsApp Session (used by Node bridge)
WHATSAPP_SESSION_PATH=./whatsapp_session

# Logging
LOG_LEVEL=info

# Python Bridge Server
PYTHON_BRIDGE_HOST=127.0.0.1
PYTHON_BRIDGE_PORT=8000

# Reminder Scheduler
SCHEDULER_ENABLED=true
SCHEDULER_POLL_INTERVAL_SECONDS=30
SCHEDULER_BATCH_SIZE=50
SCHEDULER_DELIVERY_CALLBACK_URL=http://127.0.0.1:3010
SCHEDULER_CALLBACK_SECRET=your-hmac-secret-here  # Optional: for securing callback endpoint
