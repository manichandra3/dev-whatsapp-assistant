# Example environment variables (sanitized)

# LLM Provider Configuration (Choose ONE)
# OPENAI_API_KEY=your_openai_api_key_here
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o

# Anthropic Claude (do NOT commit real keys to repo)
# ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_YOUR_KEY
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-haiku-4-5-20251001

# Google Gemini
# GOOGLE_API_KEY=REPLACE_WITH_YOUR_KEY
# LLM_PROVIDER=google
# LLM_MODEL=gemini-2.0-flash-exp

# Database
DATABASE_PATH=./data/acl_rehab.db

# WhatsApp Session
WHATSAPP_SESSION_PATH=./whatsapp_session

# Surgery Date (YYYY-MM-DD format)
SURGERY_DATE=2026-01-15

# Logging
LOG_LEVEL=info

# WhatsApp Safeguards & Features
WHATSAPP_BUSINESS_API_MODE=false
MAX_MESSAGES_PER_USER_PER_DAY=1
ENABLE_INTERACTIVE_MESSAGES=true
REQUIRE_REMINDER_OPT_IN=true
WHATSAPP_SEND_RATE_LIMIT_PER_MIN=10
